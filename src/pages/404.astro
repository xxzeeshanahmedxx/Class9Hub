---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 · Page Not Found">
  <div class="flex flex-col items-center justify-center text-center py-24 gap-5 px-4 animate-fade-in-up">
    <span class="font-display text-[64px] sm:text-[80px] font-extrabold leading-none gradient-brand" style="-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">404</span>
    <div class="space-y-1.5">
      <h1 class="font-display text-[17px] font-bold" style="color: var(--text-primary);">Nothing here</h1>
      <p class="font-body text-[14px] max-w-[240px]" style="color: var(--text-secondary);">This page doesn't exist or has been moved.</p>
    </div>
    <a href="/" class="mt-1 px-5 py-2.5 rounded-xl font-body text-[14px] font-medium" style="background: linear-gradient(135deg, var(--accent, #8cb4ff), var(--accent2, #a78bfa)); color: white; box-shadow: var(--shadow-card);" class:list={['active:scale-95']}>Go home</a>
  </div>
</Layout>
