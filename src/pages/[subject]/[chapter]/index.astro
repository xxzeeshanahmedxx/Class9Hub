---
import Layout from '../../../layouts/Layout.astro';
import SectionRow from '../../../components/SectionRow.astro';
import VideoCard from '../../../components/VideoCard.astro';
import subjects from '../../../data/subjects.json';
import mathData from '../../../data/math.json';
import physicsData from '../../../data/physics.json';
import chemistryData from '../../../data/chemistry.json';
import urduData from '../../../data/urdu.json';
import computerData from '../../../data/computer.json';
import freeilmPhysics from '../../../data/freeilm-physics.json';
import freeilmChemistry from '../../../data/freeilm-chemistry.json';
import freeilmMath from '../../../data/freeilm-math.json';

const freeilmMap = {
  physics: freeilmPhysics,
  chemistry: freeilmChemistry,
  math: freeilmMath,
};

export async function getStaticPaths() {
  const dataMap = {
    math: mathData, physics: physicsData, chemistry: chemistryData,
    urdu: urduData, computer: computerData,
  };
  const paths = [];
  for (const s of subjects) {
    const data = dataMap[s.id];
    const chapters = data.chapters || [];
    for (const ch of chapters) {
      paths.push({
        params: { subject: s.id, chapter: ch.id },
        props: { subject: s, chapter: ch, dataKind: data.kind },
      });
    }
  }
  return paths;
}

function extractTopics(videos) {
  const seen = new Set();
  return (videos || []).map(v => {
    const title = v.title || '';
    const sub = v.subtitle || '';
    const key = title + sub;
    if (seen.has(key)) return null;
    seen.add(key);
    return title + (sub ? ` (${sub})` : '');
  }).filter(Boolean).slice(0, 8);
}

const { subject, chapter, dataKind } = Astro.props;
const freeilmData = freeilmMap[subject.id];
const isExercises = dataKind === 'exercises';
const num = chapter.number || chapter.chapterNumber || '';
const chTitle = chapter.title || '';
const displayTitle = num ? `Chapter ${num}` : chTitle;
const siteUrl = 'https://class9hub.com';
const pageUrl = `${siteUrl}/${subject.id}/${chapter.id}/`;

// Gather all videos for summary (from sections if exercises, else direct)
const allVideos = isExercises
  ? (chapter.sections || []).flatMap(s => s.videos || [])
  : (chapter.videos || []);
const topics = extractTopics(allVideos);
const summaryText = topics.length > 0
  ? `This chapter covers: ${topics.join(', ')}.`
  : `Video lectures for ${subject.title} class 9 chapter ${num}.`;

const chapterDesc = `${subject.title} class 9 chapter ${num} – ${chTitle}. ${summaryText} Free video lectures for Punjab Board 2026.`;

const visibleTopics = topics.slice(0, 4).join(', ');
const visibleLine = topics.length > 0
  ? `${subject.title} Class 9 Chapter ${num} – ${chTitle}: ${visibleTopics}. Free Punjab Board video lectures.`
  : `${subject.title} Class 9 Chapter ${num} – ${chTitle}. Free Punjab Board video lectures.`;

const breadcrumbs = [
  { name: 'Home', url: siteUrl + '/' },
  { name: subject.title + ' Class 9', url: siteUrl + '/' + subject.id + '/' },
  { name: `${subject.title} Class 9 ${displayTitle}`, url: pageUrl },
];
---

<Layout
  title={`${subject.title} Class 9 ${displayTitle} – ${chTitle}`}
  subtitle={chTitle}
  desc={chapterDesc}
  colors={subject}
  backUrl={`/${subject.id}/`}
  canonical={pageUrl}
  showPWA={true}
  breadcrumbs={breadcrumbs}
  currentSubject={subject.id}
>
  {topics.length > 0 && (
    <p class="mb-5 text-[14px] leading-relaxed" style="color: var(--text-secondary);">{visibleLine}</p>
  )}
  {isExercises ? (
    <div class="flex flex-col gap-3">
      {(chapter.sections || []).map((sec, i) => (
        <div class="animate-fade-in-up" style={`animation-delay: ${i * 50}ms`}>
          <SectionRow
            number={i + 1}
            title={sec.title}
            videoCount={(sec.videos || []).length}
            href={`/${subject.id}/${chapter.id}/${sec.id}/`}
            colors={{ accent: subject.accent }}
          />
        </div>
      ))}
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {(chapter.videos || []).map((v, i) => (
        <div class="animate-fade-in-up" style={`animation-delay: ${i * 50}ms`}>
          <VideoCard
            videoId={v.videoId}
            title={v.title}
            subtitle={v.subtitle}
            duration={v.duration}
            thumb={v.thumb}
          />
        </div>
      ))}
    </div>
  )}
  {freeilmData && freeilmData[chapter.id] && (
      <div class="mt-10 p-5 rounded-xl border" style="border-color: var(--card-border); background: var(--card-bg);">
      <div class="flex items-center gap-3 mb-4">
        <svg class="w-6 h-6 shrink-0" style="color: #34a853;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <h3 class="text-lg font-semibold" style="color: #e8e8f0;">Download Freeilm.com Notes</h3>
      </div>
      <p class="text-sm mb-4" style="color: #9e9eb8;">PDF notes by Freeilm.com for {subject.title} Class 9 Chapter {chapter.number} – {chapter.title}. Includes MCQs, short questions, long questions, and numerical problems.</p>
      <div class="flex flex-col gap-2">
        {freeilmData[chapter.id].files.map((f, i) => (
          <a
            href={f.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 hover:-translate-y-0.5"
            style="background: #1a1a2e; color: #e8e8f0; text-decoration: none;"
          >
            <svg class="w-5 h-5 shrink-0" style="color: #34a853;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            <span>{f.label}</span>
            <svg class="w-4 h-4 ml-auto shrink-0" style="color: #6b6b85;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        ))}
      </div>
      <p class="text-xs mt-3" style="color: #6b6b85;">Notes provided by Freeilm.com – free study material for Pakistani students.</p>
    </div>
  )}
</Layout>
