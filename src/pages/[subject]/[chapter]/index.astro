---
import Layout from '../../../layouts/Layout.astro';
import SectionRow from '../../../components/SectionRow.astro';
import VideoCard from '../../../components/VideoCard.astro';
import subjects from '../../../data/subjects.json';
import mathData from '../../../data/math.json';
import physicsData from '../../../data/physics.json';
import chemistryData from '../../../data/chemistry.json';
import urduData from '../../../data/urdu.json';
import computerData from '../../../data/computer.json';
import biologyData from '../../../data/biology.json';
import englishData from '../../../data/english.json';

export async function getStaticPaths() {
  const dataMap = {
    math: mathData, physics: physicsData, chemistry: chemistryData,
    urdu: urduData, computer: computerData, biology: biologyData, english: englishData,
  };
  const paths = [];
  for (const s of subjects) {
    const data = dataMap[s.id];
    const chapters = data.chapters || [];
    for (const ch of chapters) {
      paths.push({
        params: { subject: s.id, chapter: ch.id },
        props: { subject: s, chapter: ch, dataKind: data.kind },
      });
    }
  }
  return paths;
}

function extractTopics(videos) {
  const seen = new Set();
  return (videos || []).map(v => {
    const title = v.title || '';
    const sub = v.subtitle || '';
    const key = title + sub;
    if (seen.has(key)) return null;
    seen.add(key);
    return title + (sub ? ` (${sub})` : '');
  }).filter(Boolean).slice(0, 8);
}

const { subject, chapter, dataKind } = Astro.props;
const isExercises = dataKind === 'exercises';
const num = chapter.number || chapter.chapterNumber || '';
const chTitle = chapter.title || '';
const displayTitle = num ? `Chapter ${num}` : chTitle;
const siteUrl = 'https://class9hub.com';
const pageUrl = `${siteUrl}/${subject.id}/${chapter.id}/`;

// Gather all videos for summary (from sections if exercises, else direct)
const allVideos = isExercises
  ? (chapter.sections || []).flatMap(s => s.videos || [])
  : (chapter.videos || []);
const topics = extractTopics(allVideos);
const summaryText = topics.length > 0
  ? `This chapter covers: ${topics.join(', ')}.`
  : `Video lectures for ${subject.title} class 9 chapter ${num}.`;

const chapterDesc = `${subject.title} class 9 chapter ${num} – ${chTitle}. ${summaryText} Free video lectures for Punjab Board 2026.`;

const visibleTopics = topics.slice(0, 4).join(', ');
const visibleLine = topics.length > 0
  ? `${subject.title} Class 9 Chapter ${num} – ${chTitle}: ${visibleTopics}. Free Punjab Board video lectures.`
  : `${subject.title} Class 9 Chapter ${num} – ${chTitle}. Free Punjab Board video lectures.`;

const breadcrumbs = [
  { name: 'Home', url: siteUrl + '/' },
  { name: subject.title + ' Class 9', url: siteUrl + '/' + subject.id + '/' },
  { name: `${subject.title} Class 9 ${displayTitle}`, url: pageUrl },
];
---

<Layout
  title={`${subject.title} Class 9 ${displayTitle} – ${chTitle}`}
  subtitle={chTitle}
  desc={chapterDesc}
  colors={subject}
  backUrl={`/${subject.id}/`}
  canonical={pageUrl}
  showPWA={true}
  breadcrumbs={breadcrumbs}
  currentSubject={subject.id}
>
  {topics.length > 0 && (
    <p class="mb-5 text-[14px] leading-relaxed" style="color: var(--text-secondary);">{visibleLine}</p>
  )}
  {isExercises ? (
    <div class="flex flex-col gap-3">
      {(chapter.sections || []).map((sec, i) => (
        <div class="animate-fade-in-up" style={`animation-delay: ${i * 50}ms`}>
          <SectionRow
            number={i + 1}
            title={sec.title}
            videoCount={(sec.videos || []).length}
            href={`/${subject.id}/${chapter.id}/${sec.id}/`}
          />
        </div>
      ))}
    </div>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {(chapter.videos || []).map((v, i) => (
        <div class="animate-fade-in-up" style={`animation-delay: ${i * 50}ms`}>
          <VideoCard
            videoId={v.videoId}
            title={v.title}
            subtitle={v.subtitle}
            duration={v.duration}
            thumb={v.thumb}
          />
        </div>
      ))}
    </div>
  )}

</Layout>
