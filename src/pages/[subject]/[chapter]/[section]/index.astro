---
import Layout from '../../../../layouts/Layout.astro';
import VideoCard from '../../../../components/VideoCard.astro';
import { subjects, getData } from '../../../../lib/data';
import { SITE_URL } from '../../../../lib/constants';
import { videoSlug } from '../../../../lib/slugify';

export async function getStaticPaths() {
  const paths = [];
  for (const s of subjects) {
    const data = getData(s.id);
    for (const ch of data.chapters || []) {
      for (const sec of ch.sections || []) {
        paths.push({
          params: { subject: s.id, chapter: ch.id, section: sec.id },
          props: { subject: s, chapter: ch, section: sec },
        });
      }
    }
  }
  return paths;
}

function extractTopics(videos) {
  const seen = new Set();
  return (videos || []).map(v => {
    const k = v.title + (v.subtitle || '');
    if (seen.has(k)) return null;
    seen.add(k);
    return v.title + (v.subtitle ? ` (${v.subtitle})` : '');
  }).filter(Boolean).slice(0, 6);
}

function parseDuration(d) {
  if (!d) return 0;
  const parts = d.split(':').map(Number);
  if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
  if (parts.length === 2) return parts[0] * 60 + parts[1];
  return 0;
}

const { subject, chapter, section } = Astro.props;
const videos = section.videos || [];
const siteUrl = SITE_URL;
const pageUrl = `${siteUrl}/${subject.id}/${chapter.id}/${section.id}/`;
const secTitle = section.title || '';
const chTitle = chapter.title || '';
const chNum = chapter.number || '';
const topics = extractTopics(videos);
const summaryText = topics.length > 0
  ? `This section covers: ${topics.join(', ')}.`
  : '';

const sectionDesc = `${subject.title} 9th ${secTitle} — ${chTitle}. ${summaryText} Free Punjab Board video lectures.`;

const breadcrumbs = [
  { name: 'Home', url: siteUrl + '/' },
  { name: subject.title, url: siteUrl + '/' + subject.id + '/' },
  { name: chTitle, url: siteUrl + '/' + subject.id + '/' + chapter.id + '/' },
  { name: secTitle, url: pageUrl },
];

// Calculate total duration
let totalSeconds = 0;
for (const v of videos) {
  totalSeconds += parseDuration(v.duration);
}
const mins = Math.floor(totalSeconds / 60);
const durationStr = `~${mins}m`;

// Extract question numbers from video titles
const questionLabels = videos.map(v => v.title).join(', ');
---

<Layout
  title={`${subject.title} 9th – ${secTitle}`}
  subtitle={`${secTitle} · ${videos.length} questions`}
  desc={sectionDesc}
  accent={subject.accent}
  backUrl={`/${subject.id}/${chapter.id}/`}
  canonical={pageUrl}
  showPWA={true}
  breadcrumbs={breadcrumbs}
>
  <!-- Breadcrumb -->
  <div class="flex items-center gap-1.5 text-[13px] mb-4 flex-wrap anim">
    <a href="/" style="color: var(--text-muted); text-decoration: none; font-weight: 500;">Home</a>
    <span style="color: var(--text-dim); font-size: 11px;">›</span>
    <a href={`/${subject.id}/`} style="color: var(--text-muted); text-decoration: none; font-weight: 500;">{subject.title}</a>
    <span style="color: var(--text-dim); font-size: 11px;">›</span>
    <a href={`/${subject.id}/${chapter.id}/`} style="color: var(--text-muted); text-decoration: none; font-weight: 500;">{chTitle}</a>
    <span style="color: var(--text-dim); font-size: 11px;">›</span>
    <span style="color: var(--text-secondary); font-weight: 600;">{secTitle}</span>
  </div>

  <!-- Exercise Hero -->
  <div class="relative py-6 sm:py-8 mb-8">
    <div class="absolute top-[-60px] left-[30%] w-[400px] h-[250px] pointer-events-none" style={`background: radial-gradient(ellipse 60% 50% at 50% 40%, ${subject.accent}10 0%, transparent 100%);`}></div>

    <div class="relative flex items-start gap-4 sm:gap-5">
      <!-- Icon -->
      <div
        class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl flex items-center justify-center flex-shrink-0 font-mono text-[18px] sm:text-[20px] font-bold text-white anim"
        style={`background: linear-gradient(135deg, ${subject.accent}90, ${subject.accent}); box-shadow: 0 0 28px ${subject.accent}30, inset 0 1px 0 rgba(255,255,255,.12);`}
      >
        {secTitle.replace('Exercise ', '').replace('Review Exercise ', 'R').replace('Exercise', 'Ex')}
      </div>

      <div class="flex-1 min-w-0">
        <!-- Tag -->
        <div
          class="anim d1 inline-flex items-center gap-2 text-[12px] font-semibold px-3 py-1 rounded-full mb-3"
          style={`background: ${subject.accent}12; color: ${subject.accent}; border: 1px solid ${subject.accent}20;`}
        >
          <span class="w-1.5 h-1.5 rounded-full" style={`background: ${subject.accent}; box-shadow: 0 0 6px ${subject.accent};`}></span>
          {subject.title} · {videos.length} questions
        </div>

        <!-- Title -->
        <h1 class="anim d2 text-[22px] sm:text-[28px] font-extrabold tracking-tight leading-tight mb-2" style="color: var(--text-primary);">
          {secTitle}
        </h1>
        <p class="anim d3 text-[15px]" style="color: var(--text-secondary);">{chTitle}</p>

        {summaryText && (
          <p class="anim d3 text-[14px] leading-relaxed mb-3" style="color: var(--text-secondary);">
            {topics.slice(0, 3).join(', ')}
          </p>
        )}

        <!-- Stats -->
        <div class="anim d4 flex flex-wrap gap-4 sm:gap-6">
          <div class="flex items-center gap-2 text-[14px]" style="color: var(--text-muted);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
            <span class="font-mono font-semibold" style="color: var(--text-primary);">{videos.length}</span>
            <span>videos</span>
          </div>
          <div class="flex items-center gap-2 text-[14px]" style="color: var(--text-muted);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span class="font-mono font-semibold" style="color: var(--text-primary);">{durationStr}</span>
            <span>total</span>
          </div>
          <div class="flex items-center gap-2 text-[14px]" style="color: var(--text-muted);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span style="color: var(--text-primary);">{questionLabels}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Videos Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {videos.map((v, i) => (
      <div class={`anim d${Math.min(i + 1, 9)}`}>
        <VideoCard
          videoId={v.videoId}
          title={v.title}
          subtitle={v.subtitle}
          duration={v.duration}
          accent={subject.accent}
          index={i}
          slug={videoSlug(subject.id, chapter.number || chapter.chapterNumber || '', v.title)}
        />
      </div>
    ))}
  </div>

  <!-- IntersectionObserver -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.anim').forEach(function(el) { observer.observe(el); });
    });
  </script>
</Layout>
