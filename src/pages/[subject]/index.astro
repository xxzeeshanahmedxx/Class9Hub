---
import Layout from '../../layouts/Layout.astro';
import ChapterRow from '../../components/ChapterRow.astro';
import subjects from '../../data/subjects.json';
import mathData from '../../data/math.json';
import physicsData from '../../data/physics.json';
import chemistryData from '../../data/chemistry.json';
import urduData from '../../data/urdu.json';
import computerData from '../../data/computer.json';

const dataMap = {
  math: mathData, physics: physicsData, chemistry: chemistryData,
  urdu: urduData, computer: computerData,
};

export async function getStaticPaths() {
  return subjects.map((s) => ({
    params: { subject: s.id },
    props: { subject: s },
  }));
}

const { subject } = Astro.props;
const data = dataMap[subject.id];
const chapters = data.chapters || [];
const isExercises = data.kind === 'exercises';
---

<Layout title={subject.title} subtitle="Select a chapter" colors={subject} backUrl="/">
  <div class="flex flex-col gap-3">
    {chapters.map((ch, i) => {
      const num = ch.number || ch.chapterNumber || i + 1;
      const chTitle = ch.title || 'Chapter ' + num;
      const row = isExercises ? (
        <ChapterRow
          number={num}
          title={chTitle}
          count={(ch.sections || []).length}
          countLabel="sections"
          href={`/${subject.id}/${ch.id}/`}
          colors={{ accent: subject.accent, soft: subject.soft }}
        />
      ) : (
        <ChapterRow
          number={num}
          title={chTitle}
          count={ch.videos ? ch.videos.length : 0}
          countLabel="videos"
          href={`/${subject.id}/${ch.id}/`}
          colors={{ accent: subject.accent, soft: subject.soft }}
        />
      );
      return <div class="animate-fade-in-up" style={`animation-delay: ${i * 50}ms`}>{row}</div>;
    })}
  </div>
</Layout>
