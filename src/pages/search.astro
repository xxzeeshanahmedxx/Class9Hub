---
import Layout from '../layouts/Layout.astro';
import { subjects, getData } from '../lib/data';
import { SITE_URL } from '../lib/constants';
import { videoSlug } from '../lib/slugify';

const dataMap = {};
subjects.forEach(s => { dataMap[s.id] = getData(s.id); });

const allVideos = [];
for (const s of subjects) {
  const data = dataMap[s.id];
  if (!data) continue;
  const chapters = data.chapters || [];
  for (const ch of chapters) {
    const chNum = ch.number || ch.chapterNumber || '';
    const videos = ch.videos || [];
    for (const v of videos) {
      if (v.title) {
        const slug = videoSlug(s.id, chNum, v.title);
        allVideos.push({
          id: v.videoId,
          title: v.title,
          subtitle: v.subtitle || '',
          subject: s.id,
          subjectTitle: s.title,
          chapterTitle: ch.title || `Chapter ${ch.number || ''}`,
          chapterId: ch.id,
          url: `/watch/${slug}/`,
          thumb: `https://i.ytimg.com/vi/${v.videoId}/hqdefault.jpg`,
        });
      }
    }
    const sections = ch.sections || [];
    for (const sec of sections) {
      for (const v of sec.videos || []) {
        if (v.title) {
          const slug = videoSlug(s.id, chNum, v.title);
          allVideos.push({
            id: v.videoId,
            title: v.title,
            subtitle: v.subtitle || '',
            subject: s.id,
            subjectTitle: s.title,
            chapterTitle: ch.title || `Chapter ${ch.number || ''}`,
            chapterId: ch.id,
            sectionId: sec.id,
            url: `/watch/${slug}/`,
            thumb: `https://i.ytimg.com/vi/${v.videoId}/hqdefault.jpg`,
          });
        }
      }
    }
  }
}

const siteUrl = SITE_URL;
const q = Astro.url.searchParams.get('q') || '';
const initialResults = q
  ? allVideos.filter(v => {
      const t = (v.title + ' ' + v.subtitle + ' ' + v.chapterTitle + ' ' + v.subjectTitle).toLowerCase();
      return t.includes(q.toLowerCase());
    }).slice(0, 30)
  : [];
---

<Layout
  title="Search Lectures – Class 9 Hub"
  desc="Search across all class 9 subjects — physics, math, chemistry, urdu, computer, biology, english. Find video lectures by topic."
  canonical={`${siteUrl}/search/`}
  noHeader={true}
>
  <div class="animate-fade-in-up pt-4">
    <h1 class="sr-only">Search Lectures – Class 9 Hub</h1>
    <div class="mb-6">
      <a href="/" class="inline-flex items-center gap-1.5 font-body text-[14px] font-medium mb-4 hover:opacity-70" style="color: var(--text-secondary);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        <span data-lang="home">Home</span>
      </a>
      <form id="search-form" action="/search/" method="GET" class="relative">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <label for="search-input" class="sr-only">Search lectures</label>
        <input
          id="search-input"
          type="text"
          name="q"
          value={q}
          placeholder="Search lectures..." data-lang="searchPlaceholder"
          autofocus
          class="w-full h-12 pl-11 pr-4 rounded-xl border font-body text-[16px] outline-none transition-all"
          style="background: var(--card-bg); border-color: var(--border); color: var(--text-primary);"
          autocomplete="off"
          aria-label="Search lectures"
        />
      </form>
    </div>

    <div id="results">
      {q && initialResults.length === 0 && (
        <div class="text-center py-12">
          <p class="font-body text-[15px]" style="color: var(--text-muted);"><span data-lang="noResults">No lectures found for</span> "{q}"</p>
          <p class="font-body text-[13px] mt-1" style="color: var(--text-muted);" data-lang="tryDiff">Try different keywords like "kinematics", "logarithms", "poetry"</p>
        </div>
      )}
      {initialResults.length > 0 && (
        <>
          <p class="font-body text-[13px] mb-3" style="color: var(--text-muted);">{initialResults.length} <span data-lang="lecturesFound">lecture(s) found</span></p>
          <div class="flex flex-col gap-2">
            {initialResults.map(v => (
              <a href={v.url} class="flex items-center gap-3 p-3 rounded-xl transition-colors active:scale-[0.98]" style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);">
                <img src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`} alt="" class="w-16 h-10 rounded-lg object-cover flex-shrink-0" loading="lazy" />
                <div class="min-w-0 flex-1">
                  <div class="font-body text-[15px] font-medium leading-snug truncate" style="color: var(--text-primary);">{v.title}{v.subtitle ? ` — ${v.subtitle}` : ''}</div>
                  <div class="font-body text-[13px] mt-0.5" style="color: var(--text-muted);">
                    <span class="font-medium" style={`color: ${subjects.find(s => s.id === v.subject)?.accent || 'var(--text-secondary)'};`}>{v.subjectTitle}</span>
                    <span class="mx-1">·</span>
                    {v.chapterTitle}
                  </div>
                </div>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); flex-shrink: 0;"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            ))}
          </div>
        </>
      )}
      {!q && (
        <div class="text-center py-12">
          <p class="font-body text-[15px]" style="color: var(--text-muted);"><span data-lang="searchAll">Search across {allVideos.length} lectures from {subjects.length} subjects</span></p>
        </div>
      )}
    </div>
  </div>

  <script is:inline>
    (function() {
      const searchIndex = JSON.parse(document.getElementById('search-data')?.textContent || '[]');
      const input = document.getElementById('search-input');
      const results = document.getElementById('results');
      const form = document.getElementById('search-form');
      if (!input || !results || !form) return;

      const subjectColors = {};
      const colorData = document.getElementById('subject-colors');
      if (colorData) {
        JSON.parse(colorData.textContent || '[]').forEach(s => { subjectColors[s.id] = s.accent; });
      }

      function escHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      function renderResults(query, items) {
        const q = query.toLowerCase().trim();
        if (!q) {
          results.innerHTML = `<div class="text-center py-12"><p class="font-body text-[15px]" style="color: var(--text-muted);">Search across ${searchIndex.length} lectures from ${Object.keys(subjectColors).length} subjects</p></div>`;
          return;
        }
        const filtered = items.filter(v => {
          const t = (v.title + ' ' + v.subtitle + ' ' + v.chapterTitle + ' ' + v.subjectTitle).toLowerCase();
          return t.includes(q);
        }).slice(0, 50);

        if (filtered.length === 0) {
          results.innerHTML = `<div class="text-center py-12"><p class="font-body text-[15px]" style="color: var(--text-muted);">No lectures found for "${escHtml(query)}"</p><p class="font-body text-[13px] mt-1" style="color: var(--text-muted);">Try different keywords like "kinematics", "logarithms", "poetry"</p></div>`;
          return;
        }

        let html = `<p class="font-body text-[13px] mb-3" style="color: var(--text-muted);">${filtered.length} lecture${filtered.length !== 1 ? 's' : ''} found</p><div class="flex flex-col gap-2">`;
        for (const v of filtered) {
          const accent = subjectColors[v.subject] || 'var(--text-secondary)';
          html += `<a href="${v.url}" class="flex items-center gap-3 p-3 rounded-xl transition-colors active:scale-[0.98]" style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);">`;
          html += `<img src="https://i.ytimg.com/vi/${v.id}/hqdefault.jpg" alt="" class="w-16 h-10 rounded-lg object-cover flex-shrink-0" loading="lazy" />`;
          html += `<div class="min-w-0 flex-1"><div class="font-body text-[15px] font-medium leading-snug truncate" style="color: var(--text-primary);">${escHtml(v.title)}${v.subtitle ? ' — ' + escHtml(v.subtitle) : ''}</div>`;
          html += `<div class="font-body text-[13px] mt-0.5" style="color: var(--text-muted);"><span class="font-medium" style="color: ${accent};">${escHtml(v.subjectTitle)}</span><span class="mx-1">·</span>${escHtml(v.chapterTitle)}</div></div>`;
          html += `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); flex-shrink: 0;"><path d="M9 18l6-6-6-6"/></svg></a>`;
        }
        html += '</div>';
        results.innerHTML = html;
        history.replaceState(null, '', '?q=' + encodeURIComponent(query));
      }

      input.addEventListener('input', () => {
        renderResults(input.value, searchIndex);
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        renderResults(input.value, searchIndex);
      });

      const urlParams = new URLSearchParams(window.location.search);
      const initialQ = urlParams.get('q');
      if (initialQ && input.value === initialQ && searchIndex.length > 0) {
        renderResults(initialQ, searchIndex);
      }
    })();
  </script>

  <script type="application/json" id="subject-colors" set:html={JSON.stringify(subjects.map(s => ({ id: s.id, accent: s.accent })))}></script>
  <script type="application/json" id="search-data" set:html={JSON.stringify(allVideos)}></script>
</Layout>
