---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Class 9 Notes – Download Free PDFs | Physics & All Subjects" desc="Download free Class 9 Punjab Board notes PDFs. Physics, Math, Chemistry, Urdu, Computer – chapter-wise solved exercises, MCQs, short & long questions.">
  <section>
    <h1 class="text-[22px] sm:text-[26px] font-bold mb-1 leading-tight" style="color: var(--text);">Free Class 9 Notes 📝</h1>
    <p class="text-[14px] sm:text-[15px] mb-6 leading-relaxed" style="color: var(--text-secondary);">Download chapter-wise solved notes with MCQs, short questions, long questions, and numericals. All subjects – Punjab Board 2026.</p>

    <div class="grid gap-4">
      <a href="/notes/physics/" class="flex items-center gap-4 px-4 min-h-[68px] rounded-xl border active:scale-[0.99] hover:[background:var(--card-hover)]" style="background: var(--card-bg); border-color: var(--card-border);">
        <span class="flex items-center justify-center w-9 h-9 rounded text-sm font-bold flex-shrink-0" style="background: #fff; color: #000;">P</span>
        <div class="min-w-0 flex-1">
          <div class="text-[16px] sm:text-[17px] font-medium" style="color: #e8e8f0;">Physics</div>
          <span class="text-[13px]" style="color: #9e9eb8;">9 chapters – solved MCQs, short/long, numericals</span>
        </div>
        <span class="text-base" style="color: #6b6b85;">&rarr;</span>
      </a>

      <!-- Add other subjects here as notes are written -->
    </div>
  </section>
</Layout>
