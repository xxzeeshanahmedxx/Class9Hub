---
import Layout from "../../../layouts/Layout.astro";

const chapters = [
  { num: "01", title: "Physical Quantities & Measurement", file: "Physics-Chapter-01-Physical-Quantities-Measurement.pdf" },
  { num: "02", title: "Kinematics", file: "Physics-Chapter-02-Kinematics.pdf" },
  { num: "03", title: "Dynamics", file: "Physics-Chapter-03-Dynamics.pdf" },
  { num: "04", title: "Turning Effect of Force", file: "Physics-Chapter-04-Turning-Effect-of-Force.pdf" },
  { num: "05", title: "Work, Energy & Power", file: "Physics-Chapter-05-Work-Energy-Power.pdf" },
  { num: "06", title: "Mechanical Properties of Matter", file: "Physics-Chapter-06-Mechanical-Properties-of-Matter.pdf" },
  { num: "07", title: "Thermal Properties of Matter", file: "Physics-Chapter-07-Thermal-Properties-of-Matter.pdf" },
  { num: "08", title: "Magnetism", file: "Physics-Chapter-08-Magnetism.pdf" },
  { num: "09", title: "Nature of Science", file: "Physics-Chapter-09-Nature-of-Science.pdf" },
];
---

<Layout title="Physics Class 9 Notes PDF – Free Download | Punjab Board" desc="Download Class 9 Physics chapter-wise notes PDF. Solved MCQs, short questions, long questions, and numericals for Punjab Board 2026 syllabus." currentSubject="physics">
  <section>
    <div class="flex items-center gap-3 mb-1">
      <a href="/notes/" class="flex items-center justify-center w-8 h-8 rounded-xl active:opacity-50 flex-shrink-0" style="color: var(--text-muted);" aria-label="Back to notes">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      </a>
      <h1 class="text-[22px] sm:text-[26px] font-bold leading-tight" style="color: var(--text);">Physics Notes</h1>
    </div>
    <p class="text-[14px] sm:text-[15px] mb-6 ml-11 leading-relaxed" style="color: var(--text-secondary);">New syllabus 2025-26. Each chapter includes MCQs, short questions, long questions & numericals in one PDF.</p>

    <div class="grid gap-3">
      {chapters.map(ch => (
        <a href={`/notes/${ch.file}`} download class="flex items-center gap-3 px-4 min-h-[60px] sm:min-h-[68px] rounded-xl border active:scale-[0.99] hover:[background:var(--card-hover)]" style="background: var(--card-bg); border-color: var(--card-border);">
          <span class="flex items-center justify-center w-8 h-8 rounded text-sm font-semibold flex-shrink-0" style="background: #fff; color: #000;">{ch.num}</span>
          <div class="min-w-0 flex-1">
            <div class="text-[15px] sm:text-[16px] font-medium leading-snug truncate" style="color: #e8e8f0;">{ch.title}</div>
            <span class="text-[12px]" style="color: #9e9eb8;">Download PDF →</span>
          </div>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6b6b85" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
      ))}
    </div>

    <div class="mt-8 p-4 rounded-xl border" style="background: var(--card-bg); border-color: var(--card-border);">
      <p class="text-[13px] leading-relaxed" style="color: #9e9eb8;">
        These notes are original content written for Class 9 Punjab Board students. Free to download and share for educational use.
      </p>
    </div>
  </section>
</Layout>
