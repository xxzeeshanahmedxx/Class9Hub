---
export interface Props {
  videoId: string;
  title: string;
  subtitle?: string;
  duration?: string;
  accent?: string;
  index?: number;
  slug?: string;
}

const {
  videoId,
  title,
  subtitle,
  duration,
  accent = '#8cb4ff',
  index = 99,
  slug = '',
} = Astro.props;

const eager = index < 3;
const thumb = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
const href = slug ? `/watch/${slug}/` : `https://www.youtube.com/watch?v=${videoId}`;
---

<a
  href={href}
  class="group video-card relative rounded-2xl overflow-hidden transition-all duration-300 block active:scale-[0.98]"
  style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
  aria-label={`Play ${title}`}
>
  <div class="relative w-full aspect-video">
    <img
      src={thumb}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={eager ? 'high' : undefined}
    />
    {duration && (
      <span
        class="absolute bottom-2 right-2 font-mono text-[11px] font-semibold px-2 py-0.5 rounded"
        style="background: rgba(0,0,0,.75); color: #fff; backdrop-filter: blur(4px); border: 1px solid rgba(255,255,255,.08);"
      >
        {duration}
      </span>
    )}
    <!-- Play overlay -->
    <div class="absolute inset-0 flex items-center justify-center transition-all duration-200">
      <div
        class="w-11 h-11 rounded-full flex items-center justify-center opacity-0 scale-75 transition-all duration-300"
        style="background: rgba(255,255,255,.9); box-shadow: 0 4px 16px rgba(0,0,0,.3);"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="margin-left: 2px; color: #111;">
          <polygon points="6,3 20,12 6,21"/>
        </svg>
      </div>
    </div>
  </div>

  <div class="px-4 pb-4 pt-3">
    <h3 class="text-[14px] sm:text-[15px] font-semibold leading-snug line-clamp-2 mb-0.5" style="color: var(--text-primary);">
      {title}
    </h3>
    {subtitle && (
      <p class="text-[13px] leading-snug line-clamp-1" style="color: var(--text-muted);">
        {subtitle}
      </p>
    )}
  </div>

  <!-- Accent inset border glow on hover -->
  <div
    class="absolute inset-0 rounded-2xl pointer-events-none opacity-0 transition-opacity duration-300"
    style={`box-shadow: inset 0 0 0 1px ${accent};`}
  />
</a>

<style is:global>
  @media (hover: hover) {
    .video-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-hover);
      border-color: var(--border-hover);
    }
    .video-card:hover .absolute.inset-0.rounded-2xl.pointer-events-none {
      opacity: 1;
    }
    .video-card:hover > div:first-child > div:last-child > div {
      opacity: 1;
      transform: scale(1);
    }
    .video-card:hover > div:first-child > div:last-child {
      background: rgba(0,0,0,.15);
    }
  }
</style>
