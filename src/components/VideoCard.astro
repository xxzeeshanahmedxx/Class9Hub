---
export interface Props {
  videoId: string;
  title: string;
  subtitle?: string;
  duration?: string;
  thumb: string;
}

const { videoId, title, subtitle, duration, thumb } = Astro.props;
---

<div>
  <button
    data-video-id={videoId}
    class="video-trigger relative w-full aspect-video rounded-xl overflow-hidden focus:outline-none active:scale-[0.98] transition-transform duration-150 touch-min"
    aria-label={`Play ${title}`}
  >
    <img src={thumb} alt={title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
    {duration && (
      <span class="absolute bottom-2 right-2 text-[11px] font-medium px-1.5 py-0.5 rounded-md" style="background: rgba(0,0,0,0.7); color: var(--text); backdrop-filter: blur(4px);">
        {duration}
      </span>
    )}
  </button>
  <h3 class="text-[14px] font-medium mt-2 leading-snug line-clamp-2" style="color: var(--text);">{title}</h3>
  {subtitle && <p class="text-[12px] mt-0.5 leading-snug line-clamp-1" style="color: var(--text-secondary);">{subtitle}</p>}
</div>
