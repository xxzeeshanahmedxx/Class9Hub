---
export interface Props {
  videoId: string;
  title: string;
  subtitle?: string;
  duration?: string;
  thumb?: string;
}

const { videoId, title, subtitle, duration, thumb = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg` } = Astro.props;
---

<div class="rounded-xl overflow-hidden" style="background: var(--card-bg);">
  <button
    data-video-id={videoId}
    class="video-trigger relative w-full aspect-video rounded-none focus:outline-none active:scale-[0.98] touch-min"
    aria-label={`Play ${title}`}
  >
    <img src={thumb} alt={title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
    {duration && (
      <span class="absolute bottom-2 right-2 text-[11px] font-medium px-1.5 py-0.5 rounded-md" style="background: var(--overlay); color: var(--color-title); backdrop-filter: blur(var(--blur-sm));">
        {duration}
      </span>
    )}
  </button>
  <div class="px-3 pb-3 pt-2">
    <h3 class="text-[14px] font-medium leading-snug line-clamp-2" style="color: var(--color-title);">{title}</h3>
    {subtitle && <p class="text-[12px] mt-0.5 leading-snug line-clamp-1" style="color: var(--color-secondary);">{subtitle}</p>}
  </div>
</div>
