---
export interface Props {
  number: number;
  title: string;
  count: number;
  countLabel: string;
  href: string;
  colors: {
    accent: string; soft: string;
  };
}

const { number, title, count, countLabel, href, colors } = Astro.props;
---

<a
  href={href}
  class="flex items-center gap-3 px-4 min-h-[60px] sm:min-h-[68px] rounded-xl border active:scale-[0.99] hover:[background:var(--card-hover)]"
  style="background: var(--card-bg); border-color: var(--card-border);"
>
  <span class="flex items-center justify-center w-8 h-8 rounded text-sm font-semibold flex-shrink-0" style="background: #fff; color: #000;">
    {number}
  </span>
  <div class="min-w-0 flex-1">
    <div class="text-[16px] sm:text-[17px] font-medium truncate" style="color: var(--color-title);">{title}</div>
    <span class="text-[14px]" style="color: var(--color-secondary);">{count} <span data-lang={countLabel}>{countLabel}</span></span>
  </div>
  <span class="text-base" style="color: var(--color-muted);">&rarr;</span>
</a>
