---
import subjects from '../data/subjects.json';

// Stats
const totalVideos = 512;
const totalSubjects = subjects.length;
---

<div class="grid grid-cols-3 gap-3 animate-fade-in-up">
  <!-- Card: Logo 9 + Tagline (col-span-2, row-span-2) -->
  <div
    class="col-span-2 row-span-2 rounded-xl p-5 sm:p-6 flex flex-col justify-center"
    style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
  >
    <span
      class="text-[56px] sm:text-[72px] font-bold leading-none gradient-brand"
      style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
    >9</span>
    <h1
      class="text-[18px] sm:text-[22px] font-bold leading-tight mt-2"
      style="color: var(--text-primary);"
      data-lang="siteName"
    >Class 9 · Punjab Curriculum</h1>
    <p
      class="text-[13px] sm:text-[14px] leading-relaxed mt-1"
      style="color: var(--text-secondary);"
      data-lang="siteDesc"
    >Free study lectures for 9th grade Punjab board students — Mathematics, Physics, Chemistry, Computer, Urdu, Biology, English.</p>
  </div>

  <!-- Card: Stats — 512 videos -->
  <div
    class="rounded-xl p-4 sm:p-5 flex flex-col justify-center"
    style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
  >
    <span class="font-mono text-[28px] sm:text-[32px] font-bold leading-none" style="color: var(--text-primary);">{totalVideos}</span>
    <span class="font-body text-[12px] sm:text-[13px] mt-1" style="color: var(--text-secondary);" data-lang="videos">videos</span>
  </div>

  <!-- Card: Stats — 7 subjects -->
  <div
    class="rounded-xl p-4 sm:p-5 flex flex-col justify-center"
    style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
  >
    <span class="font-mono text-[28px] sm:text-[32px] font-bold leading-none" style="color: var(--text-primary);">{totalSubjects}</span>
    <span class="font-body text-[12px] sm:text-[13px] mt-1" style="color: var(--text-secondary);">subjects</span>
  </div>

  <!-- Search bar link (col-span-3) -->
  <a
    href="/search/"
    class="col-span-3 rounded-xl p-4 sm:p-5 flex items-center gap-3 active:scale-[0.99] transition-transform"
    style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
    aria-label="Search lectures"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); flex-shrink: 0;" aria-hidden="true">
      <circle cx="11" cy="11" r="8" />
      <path d="M21 21l-4.35-4.35" />
    </svg>
    <span class="text-[14px] sm:text-[15px]" style="color: var(--text-muted);" data-lang="searchPlaceholder">Search lectures...</span>
  </a>

  <!-- Subject chips (col-span-3) -->
  <div class="col-span-3 flex flex-wrap gap-2">
    {subjects.map((s) => (
      <a
        href={`/${s.id}/`}
        class="inline-flex items-center px-3 py-1.5 rounded-lg text-[13px] font-medium transition-all active:scale-95"
        style={`background: ${s.accent}15; color: ${s.accent};`}
        aria-label={`${s.title} – class 9 full course`}
      >
        {s.title}
      </a>
    ))}
  </div>
</div>
