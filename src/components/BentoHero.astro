---
import subjects from '../data/subjects.json';

// Stats
const totalVideos = 512;
const totalSubjects = subjects.length;
---

<div class="flex flex-col gap-3">
  <div
    class="rounded-xl p-5 sm:p-6 flex items-center gap-3 sm:gap-4"
    style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
  >
    <span
      class="text-[32px] sm:text-[36px] font-bold leading-none gradient-brand flex-shrink-0"
      style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
    >9</span>
    <div>
      <h1
        class="text-[17px] sm:text-[19px] font-bold leading-tight"
        style="color: var(--text-primary);"
        data-lang="siteName"
      >Class 9 · Punjab Curriculum</h1>
      <p
        class="text-[14px] sm:text-[15px] leading-relaxed mt-0.5"
        style="color: var(--text-secondary);"
        data-lang="siteDesc"
      >Free study lectures for 9th grade Punjab board — 7 subjects, 512 videos.</p>
    </div>
  </div>

  <a
    href="/search/"
    class="rounded-xl p-4 sm:p-5 flex items-center gap-3 active:scale-[0.97] transition-transform duration-150 bento-search"
    style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
    aria-label="Search lectures"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); flex-shrink: 0;" aria-hidden="true">
      <circle cx="11" cy="11" r="8" />
      <path d="M21 21l-4.35-4.35" />
    </svg>
    <span class="text-[14px] sm:text-[15px]" style="color: var(--text-muted);" data-lang="searchPlaceholder">Search lectures...</span>
  </a>
</div>

<style is:global>
  @media (hover: hover) {
    .bento-search:hover {
      scale: 1.01;
      box-shadow: 0 0 20px color-mix(in srgb, var(--accent, #8cb4ff) 20%, transparent), 0 0 40px color-mix(in srgb, var(--accent, #8cb4ff) 8%, transparent) !important;
      border-color: color-mix(in srgb, var(--accent, #8cb4ff) 40%, transparent) !important;
    }
  }
</style>
