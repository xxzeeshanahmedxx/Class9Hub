---
export interface Props {
  id: string;
  title: string;
  emoji: string;
  accent: string;
}

const { id, title, accent } = Astro.props;
---

<a
  href={`/${id}/`}
  class="relative rounded-xl overflow-hidden aspect-square block active:scale-[0.95] touch-min"
  aria-label={title}
>
  <img
    src={`/assets/${id}.webp`}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
  />
</a>
