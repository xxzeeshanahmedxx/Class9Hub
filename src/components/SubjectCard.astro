---
export interface Props {
  id: string;
  title: string;
  accent: string;
  chapterCount?: number;
  videoCount?: number;
  topicRange?: string;
}

const { id, title, accent, chapterCount, videoCount, topicRange } = Astro.props;

const subjectClass = `s-${id}`;

const lucideSvgs: Record<string, string> = {
  physics: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><circle cx="12" cy="12" r="1"/><path d="M20.2 20.2c2.04-2.03.02-7.36-4.5-11.9-4.54-4.52-9.87-6.54-11.9-4.5-2.04 2.03-.02 7.36 4.5 11.9 4.54 4.52 9.87 6.54 11.9 4.5Z"/><path d="M15.7 15.7c4.52-4.54 6.54-9.87 4.5-11.9-2.03-2.04-7.36-.02-11.9 4.5-4.52 4.54-6.54 9.87-4.5 11.9 2.03 2.04 7.36.02 11.9-4.5Z"/></svg>`,
  chemistry: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/></svg>`,
  math: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>`,
  computer: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>`,
  biology: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M14 9.536V7a4 4 0 0 1 4-4h1.5a.5.5 0 0 1 .5.5V5a4 4 0 0 1-4 4 4 4 0 0 0-4 4c0 2 1 3 1 5a5 5 0 0 1-1 3"/><path d="M4 9a5 5 0 0 1 8 4 5 5 0 0 1-8-4"/><path d="M5 21h14"/></svg>`,
  urdu: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" transform="scale(-1, 1)"><path d="M15.707 21.293a1 1 0 0 1-1.414 0l-1.586-1.586a1 1 0 0 1 0-1.414l5.586-5.586a1 1 0 0 1 1.414 0l1.586 1.586a1 1 0 0 1 0 1.414z"/><path d="m18 13-1.375-6.874a1 1 0 0 0-.746-.776L3.235 2.028a1 1 0 0 0-1.207 1.207L5.35 15.879a1 1 0 0 0 .776.746L13 18"/><path d="m2.3 2.3 7.286 7.286"/><circle cx="11" cy="11" r="2"/></svg>`,
  english: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>`,
};
---

<a
  href={`/${id}/`}
  class={`group relative rounded-2xl overflow-hidden block active:scale-[0.97] transition-all duration-300 touch-min ${subjectClass}`}
  aria-label={title}
  style={`
    min-height: 180px;
    background: var(--s-gradient);
    border: 1px solid rgba(255,255,255,0.08);
  `}
>
  <!-- Bottom gradient overlay for text readability -->
  <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 15%, rgba(0,0,0,0.5) 100%); z-index: 1;"></div>

  <!-- Chapter count pill (top-left) -->
  {chapterCount && (
    <div
      class="absolute top-4 left-4 z-10 text-[11px] font-semibold uppercase tracking-[0.4px] px-2.5 py-1 rounded-full"
      style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.9);"
    >
      {chapterCount} ch
    </div>
  )}

  <!-- Frosted icon (top-right) -->
  <div
    class="absolute top-4 right-4 z-10 w-11 h-11 rounded-xl flex items-center justify-center transition-transform duration-300"
    style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.1);"
  >
    <span class="text-white" set:html={lucideSvgs[id] || ''} />
  </div>

  <!-- Content (bottom) -->
  <div class="absolute bottom-0 left-0 right-0 p-4 z-10">
    <h3 class="text-[18px] font-bold tracking-tight text-white" style="text-shadow: 0 2px 8px rgba(0,0,0,0.4);">
      {title}
    </h3>
  </div>

  <!-- Video count (bottom-right) -->
  {videoCount && (
    <div
      class="absolute bottom-4 right-4 z-10 font-mono text-[11px] font-medium"
      style="color: rgba(255,255,255,0.5);"
    >
      {videoCount} videos
    </div>
  )}

  <!-- Hover glow -->
  <div
    class="absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-300 pointer-events-none"
    style={`box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);`}
  ></div>
</a>

<style is:global>
  @media (hover: hover) {
    .s-math:hover,
    .s-physics:hover,
    .s-chemistry:hover,
    .s-biology:hover,
    .s-computer:hover,
    .s-urdu:hover,
    .s-english:hover {
      transform: translateY(-5px) scale(1.01);
      box-shadow: 0 12px 48px var(--s-glow);
      border-color: rgba(255,255,255,0.15);
    }
    .s-math:hover > div:last-child,
    .s-physics:hover > div:last-child,
    .s-chemistry:hover > div:last-child,
    .s-biology:hover > div:last-child,
    .s-computer:hover > div:last-child,
    .s-urdu:hover > div:last-child,
    .s-english:hover > div:last-child {
      opacity: 1;
    }
    .s-math:hover .w-11,
    .s-physics:hover .w-11,
    .s-chemistry:hover .w-11,
    .s-biology:hover .w-11,
    .s-computer:hover .w-11,
    .s-urdu:hover .w-11,
    .s-english:hover .w-11 {
      transform: scale(1.12) rotate(-5deg);
    }
  }
</style>
