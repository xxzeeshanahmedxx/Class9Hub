---
export interface Props {
  id: string;
  title: string;
  emoji: string;
  accent: string;
}

const { id, title, emoji, accent } = Astro.props;
---

<a
  href={`/${id}/`}
  class="group relative rounded-2xl overflow-hidden aspect-square block transition-all duration-300 hover:scale-[1.02] hover:shadow-xl"
>
  <img src={`/assets/${id}.webp`} alt={title} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-500" loading="lazy" style="position: absolute; inset: 0;" />
</a>
