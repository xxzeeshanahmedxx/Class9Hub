---
export interface Props {
  id: string;
  title: string;
  accent: string;
}

const { id, title, accent } = Astro.props;

const lucideSvgs: Record<string, string> = {
  physics: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><circle cx="12" cy="12" r="1"/><path d="M20.2 20.2c2.04-2.03.02-7.36-4.5-11.9-4.54-4.52-9.87-6.54-11.9-4.5-2.04 2.03-.02 7.36 4.5 11.9 4.54 4.52 9.87 6.54 11.9 4.5Z"/><path d="M15.7 15.7c4.52-4.54 6.54-9.87 4.5-11.9-2.03-2.04-7.36-.02-11.9 4.5-4.52 4.54-6.54 9.87-4.5 11.9 2.03 2.04 7.36.02 11.9-4.5Z"/></svg>`,
  chemistry: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/></svg>`,
  math: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>`,
  computer: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><rect width="18" height="12" x="3" y="4" rx="2" ry="2"/><line x1="2" x2="22" y1="20" y2="20"/></svg>`,
  biology: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><path d="M14 9.536V7a4 4 0 0 1 4-4h1.5a.5.5 0 0 1 .5.5V5a4 4 0 0 1-4 4 4 4 0 0 0-4 4c0 2 1 3 1 5a5 5 0 0 1-1 3"/><path d="M4 9a5 5 0 0 1 8 4 5 5 0 0 1-8-4"/><path d="M5 21h14"/></svg>`,
  urdu: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32" transform="scale(-1, 1)"><path d="M15.707 21.293a1 1 0 0 1-1.414 0l-1.586-1.586a1 1 0 0 1 0-1.414l5.586-5.586a1 1 0 0 1 1.414 0l1.586 1.586a1 1 0 0 1 0 1.414z"/><path d="m18 13-1.375-6.874a1 1 0 0 0-.746-.776L3.235 2.028a1 1 0 0 0-1.207 1.207L5.35 15.879a1 1 0 0 0 .776.746L13 18"/><path d="m2.3 2.3 7.286 7.286"/><circle cx="11" cy="11" r="2"/></svg>`,
  english: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>`,
};
---
<a
  href={`/${id}/`}
  class="group subject-card relative rounded-xl overflow-hidden aspect-square block active:scale-[0.96] transition-transform duration-150 touch-min"
  aria-label={title}
  style="--accent: {accent}; background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
>
  <div
    class="absolute inset-0"
    style={`background: linear-gradient(145deg, ${accent}40 0%, ${accent}15 60%, var(--card-bg) 100%);`}
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent pointer-events-none" />

  <div class="relative flex flex-col items-center justify-center h-full -translate-y-2 p-3">
    <div class="subject-icon" set:html={lucideSvgs[id] || ''} />
    <span class="mt-4 font-display text-[14px] sm:text-[15px] font-bold leading-tight text-white text-center">
      {title}
    </span>
  </div>

  <div
    class="absolute inset-0 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
    style={`box-shadow: inset 0 0 0 1px ${accent};`}
  />
</a>

<style is:global>
  .subject-icon svg {
    width: 48px;
    height: 48px;
  }
  @media (hover: hover) {
    .subject-card:hover {
      scale: 1.03;
      box-shadow: 0 0 20px color-mix(in srgb, var(--accent, #8cb4ff) 35%, transparent), 0 0 40px color-mix(in srgb, var(--accent, #8cb4ff) 18%, transparent) !important;
    }
    .subject-card:hover .subject-icon svg {
      transform: rotate(-6deg) scale(1.12);
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
  }
</style>
